{
  "name": "md-code",
  "version": "1.0.0",
  "description": "Professional-grade markdown editor with live preview, multi-tab support, and export to HTML/PDF/PNG/JPG.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.mdcode.app",
    "productName": "MD Code",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "M (1).svg"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown File"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "description": "Markdown File"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MD Code",
      "artifactName": "MD-Code-${version}-Setup.${ext}"
    }
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "marked": "^15.0.7",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.2"
  }
}
